{
  "name": "fraserpayv2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "dev": "next dev",
    "dev:emulators": "firebase emulators:start --only auth,firestore --project demo-fraserpay",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.mts",
    "test:integration:emulate": "firebase emulators:exec --only auth,firestore --project demo-fraserpay \"pnpm test:integration\"",
    "seed:dev": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/seed-dev-data.ts",
    "seed:dev:emulate": "firebase emulators:exec --only auth,firestore --project demo-fraserpay \"pnpm seed:dev\"",
    "seed:superadmin": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/seed-superadmin.ts",
    "seed:superadmin:emulate": "firebase emulators:exec --only auth,firestore --project demo-fraserpay \"pnpm seed:superadmin\"",
    "verify:ledger": "node --env-file-if-exists=.env --env-file-if-exists=.env.local --import tsx scripts/verify-ledger.ts",
    "verify:ledger:emulate": "firebase emulators:exec --only firestore --project demo-fraserpay \"pnpm verify:ledger\"",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
